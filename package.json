{
  "name": "agentario",
  "version": "0.1.0",
  "description": "AI agent library — browse on the web or pull prompts from the terminal",
  "private": false,
  "type": "module",
  "bin": {
    "agentario": "./bin/agentario.mjs"
  },
  "files": [
    "bin",
    "data/catalog.json",
    "data/agents.ts",
    "app",
    "components",
    "lib",
    "public",
    "middleware.ts",
    "wrangler.jsonc",
    "open-next.config.ts",
    "next.config.ts",
    "postcss.config.mjs",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "node ./scripts/build.mjs",
    "build:next": "npm run export:catalog && next build",
    "build:cf": "OPEN_NEXT_BUILDING=1 opennextjs-cloudflare build",
    "start": "next start",
    "lint": "eslint",
    "export:catalog": "tsx scripts/export-catalog.ts",
    "agentario": "node ./bin/agentario.mjs",
    "menu": "node ./bin/agentario.mjs",
    "prepack": "npm run export:catalog",
    "preview": "npm run build:cf && opennextjs-cloudflare preview",
    "deploy": "npm run build:cf && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "agents",
    "prompts",
    "cli",
    "llm",
    "opensource"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/enmanuelcanelon/Agentario.git"
  },
  "bugs": {
    "url": "https://github.com/enmanuelcanelon/Agentario/issues"
  },
  "homepage": "https://github.com/enmanuelcanelon/Agentario#readme",
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "wrangler": "^4.110.0"
  }
}
